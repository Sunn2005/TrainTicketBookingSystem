<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="iuh.fit.gui.ticket.exchange.ExchangeTicketController"
            stylesheets="@../ticket.css">

    <VBox spacing="0" style="-fx-background-color:#f5f7fa;">

        <VBox styleClass="cancel-page-header" spacing="4">
        <padding><Insets top="20" right="28" bottom="16" left="28"/></padding>
        <Label text="Đổi Vé" styleClass="cancel-page-title"/>
        <Label text="Nhập mã vé để tra cứu và thực hiện hủy vé"
               styleClass="cancel-page-subtitle"/>
    </VBox>

        <!-- Step bar -->
        <HBox alignment="CENTER" spacing="8"
              style="-fx-background-color:white;-fx-border-color:#e0e0e0;
                     -fx-border-width:0 0 1 0;-fx-padding:14 0 14 0;">
            <Label fx:id="stepLookup" text="1  Tra cứu vé"/>
            <Label text="───" style="-fx-text-fill:#ccc;"/>
            <Label fx:id="stepChoose" text="2  Chọn chuyến mới"/>
            <Label text="───" style="-fx-text-fill:#ccc;"/>
            <Label fx:id="stepConfirm" text="3  Xác nhận"/>
        </HBox>

        <VBox spacing="20" style="-fx-padding:28;">

            <!-- Lookup form -->
            <VBox spacing="14" styleClass="cancel-card">
                <Label text="THÔNG TIN VÉ CẦN ĐỔI"
                       style="-fx-font-weight:bold;-fx-font-size:13px;-fx-text-fill:-color-primary;"/>

                <GridPane hgap="14" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="130" prefWidth="140"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Mã vé *" styleClass="info-label"
                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="ticketIdField" promptText="Ví dụ: TIC-001"
                               styleClass="form-field"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="CCCD (tùy chọn)" styleClass="info-label"
                           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="cccdField" promptText="Bỏ trống nếu không cần xác minh"
                               styleClass="form-field"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                </GridPane>

                <Label fx:id="statusLabel" text="" wrapText="true"/>

                <HBox spacing="10">
                    <Button fx:id="lookupBtn" text="🔍  Tra cứu"
                            onAction="#onLookup" styleClass="btn-primary"/>
                    <Button text="← Quay lại" onAction="#onCancel"
                            styleClass="btn-secondary"/>
                </HBox>
            </VBox>

            <!-- Ticket info card -->
            <VBox fx:id="ticketInfoCard" spacing="14"
                  style="-fx-background-color:white;-fx-background-radius:10;
                         -fx-border-color:-color-primary;-fx-border-radius:10;
                         -fx-border-width:2;-fx-padding:20;
                         -fx-effect:dropshadow(gaussian,rgba(0,119,200,0.15),10,0,0,3);">

                <Label text="VÉ HIỆN TẠI"
                       style="-fx-font-weight:bold;-fx-font-size:13px;-fx-text-fill:-color-primary;"/>

                <VBox style="-fx-background-color:#f0f8ff;-fx-background-radius:8;-fx-padding:14;"
                      spacing="8">

                    <HBox spacing="8">
                        <Label text="Mã vé:" styleClass="info-label"/>
                        <Label fx:id="lblTicketId" text="—"
                               style="-fx-font-weight:bold;-fx-text-fill:#0077c8;"/>
                    </HBox>
                    <HBox spacing="8">
                        <Label text="Tàu:" styleClass="info-label"/>
                        <Label fx:id="lblTrain" text="—" styleClass="info-value"/>
                    </HBox>
                    <HBox spacing="8">
                        <Label text="Tuyến:" styleClass="info-label"/>
                        <Label fx:id="lblRoute" text="—" styleClass="info-value"/>
                    </HBox>
                    <HBox spacing="8">
                        <Label text="Khởi hành:" styleClass="info-label"/>
                        <Label fx:id="lblDeparture" text="—" styleClass="info-value"/>
                    </HBox>
                    <HBox spacing="8">
                        <Label text="Ghế:" styleClass="info-label"/>
                        <Label fx:id="lblSeat" text="—" styleClass="info-value"/>
                    </HBox>
                    <HBox spacing="8">
                        <Label text="Giá vé:" styleClass="info-label"/>
                        <Label fx:id="lblPrice" text="—"
                               style="-fx-font-weight:bold;-fx-text-fill:#dc2626;"/>
                    </HBox>
                    <HBox spacing="8">
                        <Label text="Thanh toán:" styleClass="info-label"/>
                        <Label fx:id="lblPaymentStatus" text="—" styleClass="info-value"/>
                    </HBox>
                    <HBox spacing="8">
                        <Label text="Trạng thái:" styleClass="info-label"/>
                        <Label fx:id="lblTicketStatus" text="—" styleClass="info-value"/>
                    </HBox>
                </VBox>

                <Label text="⚠  Phí đổi vé tùy thuộc vào thời gian còn lại trước giờ khởi hành."
                       wrapText="true" styleClass="policy-label"
                       style="-fx-background-color:#fffbeb;-fx-background-radius:6;
                              -fx-padding:8 12 8 12;-fx-border-color:#fcd34d;
                              -fx-border-radius:6;"/>

                <Button fx:id="continueBtn"
                        text="Tiếp tục → Chọn chuyến mới"
                        onAction="#onContinue"
                        styleClass="btn-confirm"/>
            </VBox>

        </VBox>
    </VBox>
</ScrollPane>