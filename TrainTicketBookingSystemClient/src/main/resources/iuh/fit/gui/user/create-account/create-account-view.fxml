<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="iuh.fit.gui.user.create_account.CreateAccountScreenController"
      styleClass="ca-page-root"
      stylesheets="@create-account.css"
      spacing="0">

    <!-- Header -->
    <VBox styleClass="ca-header" spacing="4">
        <padding><Insets top="20" right="28" bottom="16" left="28"/></padding>
        <Label text="Quản Lý Tài Khoản" styleClass="ca-header-title"/>
        <Label text="Tạo tài khoản mới và quản lý người dùng"
               styleClass="ca-header-subtitle"/>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="ca-scroll">
        <VBox spacing="20">
            <padding><Insets top="24" right="28" bottom="28" left="28"/></padding>

            <!-- Form -->
            <VBox styleClass="ca-card" spacing="14">
                <Label text="TẠO TÀI KHOẢN MỚI" styleClass="ca-card-title"/>

                <GridPane hgap="16" vgap="4">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <!-- Tên đăng nhập -->
                    <VBox spacing="3" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Tên đăng nhập *" styleClass="ca-field-label"/>
                        <TextField fx:id="usernameField" styleClass="ca-form-field"
                                   promptText="4-20 ký tự, chữ/số/_ (VD: nv006)"/>
                        <Label fx:id="usernameError" styleClass="ca-error-label"
                               visible="false" managed="false"/>
                    </VBox>

                    <!-- Họ và tên -->
                    <VBox spacing="3" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Họ và tên *" styleClass="ca-field-label"/>
                        <TextField fx:id="fullNameField" styleClass="ca-form-field"
                                   promptText="Chỉ chữ cái và khoảng trắng (VD: Nguyễn Văn A)"/>
                        <Label fx:id="fullNameError" styleClass="ca-error-label"
                               visible="false" managed="false"/>
                    </VBox>

                    <!-- Mật khẩu -->
                    <VBox spacing="3" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="Mật khẩu *" styleClass="ca-field-label"/>
                        <PasswordField fx:id="passwordField" styleClass="ca-form-field"
                                       promptText="Tối thiểu 6 ký tự, có cả chữ và số (VD: abc123)"/>
                        <Label fx:id="passwordError" styleClass="ca-error-label"
                               visible="false" managed="false"/>
                    </VBox>

                    <!-- Xác nhận mật khẩu -->
                    <VBox spacing="3" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="Xác nhận mật khẩu *" styleClass="ca-field-label"/>
                        <PasswordField fx:id="confirmPasswordField" styleClass="ca-form-field"
                                       promptText="Nhập lại mật khẩu"/>
                        <Label fx:id="confirmPasswordError" styleClass="ca-error-label"
                               visible="false" managed="false"/>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="3" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="Email *" styleClass="ca-field-label"/>
                        <TextField fx:id="emailField" styleClass="ca-form-field"
                                   promptText="VD: example@gmail.com"/>
                        <Label fx:id="emailError" styleClass="ca-error-label"
                               visible="false" managed="false"/>
                    </VBox>

                    <!-- Vai trò -->
                    <VBox spacing="3" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label text="Vai trò *" styleClass="ca-field-label"/>
                        <ComboBox fx:id="roleCombo" styleClass="ca-combo" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Trạng thái -->
                    <VBox spacing="3" GridPane.columnIndex="0" GridPane.rowIndex="3">
                        <Label text="Trạng thái *" styleClass="ca-field-label"/>
                        <ComboBox fx:id="statusCombo" styleClass="ca-combo" maxWidth="Infinity"/>
                    </VBox>

                </GridPane>

                <Label fx:id="formStatusLabel" text="" wrapText="true" minHeight="20"/>

                <HBox spacing="12">
                    <Button fx:id="createBtn" text="✔  Tạo tài khoản"
                            onAction="#onCreate" styleClass="ca-btn-primary"/>
                    <Button text="✕  Xóa form" onAction="#onClear"
                            styleClass="ca-btn-secondary"/>
                </HBox>
            </VBox>

            <!-- Bảng danh sách -->
            <VBox styleClass="ca-card" spacing="12">
                <HBox alignment="CENTER_LEFT">
                    <Label text="DANH SÁCH TÀI KHOẢN" styleClass="ca-card-title"
                           HBox.hgrow="ALWAYS"/>
                    <Button text="⟳  Làm mới" onAction="#onRefresh"
                            styleClass="ca-btn-secondary"/>
                </HBox>

                <TableView fx:id="userTable" styleClass="ca-table" prefHeight="280">
                    <columns>
                        <TableColumn fx:id="colUsername" text="Tên đăng nhập" prefWidth="150"/>
                        <TableColumn fx:id="colFullName" text="Họ và tên" prefWidth="180"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                        <TableColumn fx:id="colRole" text="Vai trò" prefWidth="120"/>
                        <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="110"/>
                        <TableColumn fx:id="colAction" text="Hành động" prefWidth="130"/>
                    </columns>
                    <placeholder>
                        <Label text="Không có dữ liệu."
                               style="-fx-text-fill:#aaa;-fx-font-size:13px;"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>