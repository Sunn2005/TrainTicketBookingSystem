<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="540.0" prefWidth="720.0" stylesheets="@forgot-password.css"
           xmlns:fx="http://javafx.com/fxml" fx:controller="iuh.fit.gui.login.ForgotPasswordScreenController"
           styleClass="forgot-root">
    <VBox alignment="TOP_CENTER" maxWidth="520.0" spacing="14.0" styleClass="forgot-panel">
        <padding>
            <Insets bottom="26.0" left="24.0" right="24.0" top="26.0"/>
        </padding>

        <Label styleClass="forgot-title" text="Gửi yêu cầu cấp lại mật khẩu"/>
        <Label styleClass="forgot-subtitle" text="Áp dụng cho EMPLOYEE / MANAGER"/>

        <VBox spacing="6.0" styleClass="form-section">
            <Label styleClass="form-label" text="Username *"/>
            <TextField fx:id="usernameField" promptText="VD: johndoe" styleClass="form-field"/>
        </VBox>

        <VBox spacing="6.0" styleClass="form-section">
            <Label styleClass="form-label" text="Họ và tên *"/>
            <TextField fx:id="fullNameField" promptText="Nguyễn Văn A" styleClass="form-field"/>
        </VBox>

        <VBox spacing="6.0" styleClass="form-section">
            <Label styleClass="form-label" text="Vai trò *"/>
            <ComboBox fx:id="roleCombo" maxWidth="1.7976931348623157E308" styleClass="form-field"/>
        </VBox>

        <VBox spacing="6.0" styleClass="form-section">
            <Label styleClass="form-label" text="Email *"/>
            <TextField fx:id="emailField" promptText="example@gmail.com" styleClass="form-field"/>
        </VBox>

        <Label fx:id="statusLabel" styleClass="status-text" text="" wrapText="true"/>

        <HBox spacing="12.0">
            <Button fx:id="submitButton" maxWidth="1.7976931348623157E308" onAction="#onSubmit"
                    styleClass="primary-button" text="Gửi yêu cầu" HBox.hgrow="ALWAYS"/>
            <Button maxWidth="1.7976931348623157E308" onAction="#onClose" styleClass="secondary-button"
                    text="Đóng" HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>
</StackPane>
