<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.PieChart?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="iuh.fit.gui.statistics.RevenueBySeatTypeController"
      spacing="0"
      styleClass="cm-page-root"
      stylesheets="@revenue-by-time.css">

    <!-- HEADER -->
    <VBox styleClass="cm-header" spacing="4">
        <padding>
            <Insets top="20" right="28" bottom="18" left="28"/>
        </padding>

        <Label text="Thống Kê Doanh Thu"
               styleClass="cm-header-title"/>

        <Label text="Theo loại ghế"
               styleClass="cm-header-subtitle"/>

    </VBox>

    <!-- CONTENT -->
    <ScrollPane fitToWidth="true"
                VBox.vgrow="ALWAYS"
                styleClass="cm-scroll">

        <VBox spacing="18">
            <padding>
                <Insets top="24" right="28" bottom="28" left="28"/>
            </padding>

            <HBox spacing="16">

                <!-- TOTAL REVENUE CARD -->
                <VBox HBox.hgrow="ALWAYS"
                      styleClass="cm-card"
                      spacing="10">

                    <Label text="Tổng doanh thu"
                           styleClass="cm-card-label"/>

                    <Label fx:id="totalRevenue"
                           text="0"
                           styleClass="cm-total-number"/>
                </VBox>

                <!-- REFRESH BUTTON CARD -->
                <VBox alignment="CENTER_LEFT"
                      HBox.hgrow="NEVER"
                      prefWidth="180">

                    <Button text="Làm mới"
                            onAction="#onRefresh"
                            styleClass="cm-btn-primary"/>
                </VBox>

            </HBox>

            <HBox spacing="16">
                <!-- PIE CHART LEFT -->
                <VBox styleClass="cm-card" spacing="12"
                      HBox.hgrow="ALWAYS"
                      prefWidth="400">

                    <Label text="BIỂU ĐỒ DOANH THU"
                           styleClass="cm-section-title"/>

                    <PieChart fx:id="pieChart"
                              prefHeight="420"
                              VBox.vgrow="ALWAYS"/>
                </VBox>

                <!-- TABLE RIGHT -->
                <VBox styleClass="cm-card" spacing="12"
                      HBox.hgrow="ALWAYS">

                    <Label text="CHI TIẾT"
                           styleClass="cm-section-title"/>

                    <TableView fx:id="table"
                               prefHeight="420"
                               VBox.vgrow="ALWAYS"
                               styleClass="cm-table">

                        <columns>
                            <TableColumn fx:id="colType" text="Loại ghế"/>
                            <TableColumn fx:id="colCount" text="Số lượng"/>
                            <TableColumn fx:id="colRevenue" text="Doanh thu"/>
                        </columns>

                    </TableView>
                </VBox>

            </HBox>

        </VBox>
    </ScrollPane>
</VBox>